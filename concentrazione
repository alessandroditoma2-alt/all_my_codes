library(dplyr)

MES <- settori %>%
  filter(ateco_3cifre %in% c(101, 105, 107)) %>%   
  group_by(anno, ateco_3cifre) %>%
  arrange(desc(ricavi), .by_group = TRUE) %>%
  mutate(rank = row_number()) %>%
  summarise(
    fatt_tot = sum(ricavi, na.rm = TRUE),
    top3 = mean(ricavi[rank <= 3], na.rm = TRUE),
    MES = top3 / fatt_tot,
    .groups = "drop"
  )

