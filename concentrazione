cr10_1102 <- settori %>%
  filter(ateco_4cifre == "1102") %>%
  group_by(anno) %>%
  arrange(desc(ricavi), .by_group = TRUE) %>%
  mutate(tot = sum(ricavi, na.rm = TRUE)) %>%
  slice_head(n = 10) %>%
  summarise(
    CR10 = sum(ricavi) / first(tot),
