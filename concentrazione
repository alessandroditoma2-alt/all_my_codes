  )

library(tidyverse)
library(janitor)
library(stringr)

Conc_patr_netto <- Conc_patr_netto %>%
  mutate(
    across(
      starts_with("totale_patrimonio_netto"),
      ~ as.numeric(str_replace_all(., "[^0-9.-]", ""))
    )
  ) %>%
  pivot_longer(
    cols = starts_with("totale_patrimonio_netto"),
    names_to = "anno",
    values_to = "patr_netto"
  ) %>%
  mutate(
    anno = as.numeric(str_extract(anno, "\\d{4}"))
  )

Conc_patr_netto_clean <- Conc_patr_netto %>%
  filter(!is.na(patr_netto))

Conc_patr_netto_clean <- Conc_patr_netto %>%
  filter(!is.na(patr_netto), patr_netto > 0)

library(dplyr)

HHIpn <- Conc_patr_netto_clean %>%
  filter(ateco_4cifre %in% c("1102", "1105")
  ) %>%
  group_by(ateco_4cifre, anno) %>%
  mutate(share = patr_netto / sum(patr_netto)) %>%
  summarise(HHIpn = sum(share^2), .groups = "drop")

HHIpn2 <- Conc_patr_netto_clean %>%
  filter(ateco_3cifre %in% c("101", "105", "107")) %>%
  group_by(ateco_3cifre, anno) %>%
  mutate(share = patr_netto / sum(patr_netto)) %>%
  summarise(HHIpn2 = sum(share^2), .groups = "drop")

